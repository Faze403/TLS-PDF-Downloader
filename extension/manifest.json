{
  "manifest_version": 3,
  "name": "TLS PDF Downloader",
  "version": "0.1.0",
  "description": "TLS/Coursemos ubdoc 문서 페이지를 PDF로 저장합니다.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "downloads",
    "storage"
  ],
  "host_permissions": [
    "https://doc.coursemos.co.kr/*",
    "https://*/local/ubdoc/*",
    "http://*/local/ubdoc/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*/local/ubdoc/*",
        "http://*/local/ubdoc/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "TLS PDF Downloader",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
